{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && echo 'Build complete (tsx runtime, no tsc needed)'",
    "dev": "tsx watch src/index.ts",
    "start": "prisma migrate resolve --rolled-back 00000000000000_initial_schema 2>/dev/null; prisma migrate deploy && node --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "prisma generate",
    "supervisor": "tsx src/services/supervisor/index.ts",
    "cleanup": "tsx src/workers/cleanup.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sse": "^0.4.0",
    "@fastify/static": "^9.0.0",
    "@myfuckingmusic/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sinclair/typebox": "^0.34.48",
    "apns2": "^12.2.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.71.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.0",
    "ioredis": "^5.4.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.0",
    "pino": "^10.3.0"
  },
  "devDependencies": {
    "@myfuckingmusic/tsconfig": "workspace:*",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.0",
    "prisma": "^7.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
